# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.eggs/
*.egg-info/
*.egg
build/
dist/

# Env / secrets
.env
.env.local
*.key

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Runtime cache (we keep the dir but ignore its contents by default,
# then whitelist the small JSON/asset trees below — see audit in the
# 2026-04-26 commit for sizing).
data/cache/*
!data/cache/.gitkeep

# ✅ Tracked: the demo-defining JSON caches. Re-running the pipeline
# from scratch on a fresh machine without these takes 30+ minutes and
# burns ~$50 of Gemini/Opus/Scenario credits, so we ship them.
!data/cache/reports/
!data/cache/reports/**
!data/cache/game_dna/
!data/cache/game_dna/**
# Knowledge base: ~500 Gemini Pro Vision deconstructions (~2 MB,
# ~$2-3 of API calls + 30 min wall-clock). Ships with the repo so any
# clone can demo /weekly + /ad/$id with the full hook dossier.
!data/cache/deconstruct/
!data/cache/deconstruct/**
!data/cache/game_fit/
!data/cache/game_fit/**
!data/cache/briefs/
!data/cache/briefs/**
!data/cache/voodoo/
!data/cache/voodoo/**
!data/cache/sensortower/
!data/cache/sensortower/**
!data/cache/scenario/
!data/cache/scenario/**
!data/cache/video_briefs/
!data/cache/video_briefs/**
!data/cache/e2e/
!data/cache/e2e/**

# ✅ Endcards: hand-curated brand assets (one PNG + one MP4 per Voodoo
# game). Every deploy needs them on disk for /api/variants/render-video.
!data/cache/endcards/
!data/cache/endcards/**

# ✅ Audio library + cached TTS + SFX — the READMEs explain which mp3s
# to drop in for the multi-layer soundtrack overlay (music bed, voice,
# game SFX). Generated/AI music tracks land in data/cache/audio/generated/
# and stay ignored (regeneration is cheap and they pollute the repo).
!data/cache/audio/
!data/cache/audio/library/
!data/cache/audio/library/**
!data/cache/audio/tts/
!data/cache/audio/tts/**
!data/cache/audio/sfx/
!data/cache/audio/sfx/**
data/cache/audio/generated/

# ❌ Stays ignored — too large or genuinely ephemeral:
#  - data/cache/videos/         512 MB of variant + endcard mp4s, regenerated by each user
#  - data/cache/screenshots/    126 MB, re-fetched on demand from SensorTower
#  - data/cache/scenario_frames/  32 MB of upload-temp PNGs
#  - data/cache/scenario_assets/  Scenario-side asset metadata
#  - data/cache/compare/        14 MB of model-comparison HTML grids (dev tool)
#  - data/cache/video_renders/  per-render scratch space
# PM-uploaded screenshots/mockups for the prototype mode
data/uploads/
# Notebook stray cache (shouldn't happen anymore — modules now resolve to repo root)
notebooks/data/

# Parallel sub-agent experiments (kept on disk, untracked)
voodradar-codex/

# Notebooks
# We work in .py jupytext format. Convert on demand with:
#   uv run jupytext --to ipynb notebooks/<file>.py
# .ipynb files are never committed — their outputs can leak secrets (e.g. API
# tokens captured in httpx INFO logs are inlined into cell outputs).
.ipynb_checkpoints/
*.ipynb_meta
*.ipynb
**/Untitled*.py

# Test / coverage
.pytest_cache/
.coverage
htmlcov/

# uv
uv.lock

# Frontend deps
front/node_modules/
front/dist/
front/.tanstack/

# Voodoo brand assets (reference only, not used at runtime)
voodooio_logo.*
*.brief.json
/genius-*.json
# Stray mp4 downloads at repo root (e.g. user-downloaded variant ad
# previews from the UI). Real outputs live under data/cache/videos/.
/variant_*.mp4
/demo_*.mp4
# Pitch decks and Office lock files at repo root — kept on disk for
# the user but never tracked (the pptx is a working file, the ~$
# prefix is PowerPoint's open-file lock).
*.pptx
*.pptx.bak
~$*
/data/*.zip
/data/cache.zip

# Stray mp3 downloads at repo root — should land in data/cache/audio/library/
/*.mp3
