# SensorTower — provided by Voodoo Hack
SENSORTOWER_API_KEY=

# Gemini — provided by Voodoo Hack (used for video analysis + Game DNA from screenshots)
GEMINI_API_KEY=

# Anthropic — Claude credits provided
ANTHROPIC_API_KEY=

# Scenario
# - In production, Partner 2 uses the Scenario MCP (no API key needed in .env, OAuth via Claude Code).
# - For the e2e learning notebook (notebooks/02_pipeline_e2e.py), we use Scenario's REST API which
#   requires Basic auth: combine SCENARIO_API_KEY:SCENARIO_API_SECRET, base64-encode, set as Authorization header.
SCENARIO_API_KEY=
SCENARIO_API_SECRET=

# Tuning
HOOKLENS_MAX_CREATIVES=80
HOOKLENS_GEMINI_CONCURRENCY=5
HOOKLENS_CACHE_DIR=./data/cache
